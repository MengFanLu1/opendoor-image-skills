# OpenDoor Image Skills 配置
# 复制此文件为 .env 并填入你的 API 密钥
# cp .env.example .env

# API 密钥（必填）- 从 https://api.code-opendoor.com 获取
OPENDOOR_IMAGE_API_KEY=

# API 基础地址（可选）
# OPENDOOR_IMAGE_API_BASE=https://api.code-opendoor.com

# 默认模型（可选）: gemini-3.1-flash-image / gemini-3-pro-image-preview / gpt-image-2
# OPENDOOR_IMAGE_MODEL=gemini-3.1-flash-image

# 图片保存目录（可选）
# OPENDOOR_IMAGE_OUTPUT_DIR=~/generated_images

# 图片尺寸，仅 gpt-image-2 有效（可选）
# OPENDOOR_IMAGE_SIZE=1024x1024

# 图片质量，仅 gpt-image-2 有效: low/medium/high（可选）
# OPENDOOR_IMAGE_QUALITY=low
